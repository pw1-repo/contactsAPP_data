<tr>
    <th scope="row" class="text-start">
        <%= contact.nome.substring(0, contact.nome.indexOf(' ')) %>
    </th>
    <td>
        <%= contact.nome %>
    </td>
    <td>
        <%= contact.telefone %>
    </td>
    <td>
        <%= contact.email %>
    </td>
    <td>
        <a href="/toggle_favorito?nome=<%= encodeURIComponent(contact.nome) %>" class="btn btn-outline-secondary">
        <% if (contact.favorito) { %>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M16 14q-.425 0-.712-.288T15 13t.288-.712T16 12h6q.425 0 .713.288T23 13t-.288.713T22 14zm-5.7 6.2q-.35-.125-.625-.4q-1.1-1-2.6-2.275t-2.85-2.737t-2.287-3.063T1 8.475q0-2.35 1.575-3.912T6.5 3q1.3 0 2.475.538T11 5.075q.85-1 2.025-1.537T15.5 3q1.575 0 2.788.738T20.2 5.6q.275.475-.087.963T19.075 7h-.4q-2.125 0-3.9 1.713T13 13q0 1.05.338 1.988T14.4 16.7q.275.3.238.7t-.338.675l-1.975 1.75q-.275.275-.625.388t-.7.112t-.7-.125"/>
                </svg>
        <% } else { %>  
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M18 17v-3h-3v-2h3V9h2v3h3v2h-3v3zm-7 4l-3.175-2.85q-1.8-1.625-3.088-2.9t-2.125-2.4t-1.225-2.175T1 8.475q0-2.35 1.575-3.912T6.5 3q1.3 0 2.475.538T11 5.075q.85-1 2.025-1.537T15.5 3q2.125 0 3.563 1.288T20.85 7.3q-.45-.175-.9-.262t-.875-.088q-2.525 0-4.3 1.763T13 13q0 1.3.525 2.463T15 17.45q-.475.425-1.237 1.088T12.45 19.7z"/>
                </svg>
        <% } %>
        </a>
        <a href="/delete/<%= encodeURIComponent(contact.nome) %>" class="btn btn-outline-danger">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
                <path fill="currentColor" d="M7 21q-.825 0-1.412-.587T5 19V6H4V4h5V3h6v1h5v2h-1v13q0 .825-.587 1.413T17 21zm2-4h2V8H9zm4 0h2V8h-2z"/>
            </svg>
        </a>
        <a href="/form/<%= encodeURIComponent(contact._id) %>" class="btn btn-outline-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                <path fill="currentColor" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1.003 1.003 0 0 0 0-1.41l-2.34-2.34a1.003 1.003 0 0 0-1.41 0l-1.83 1.83l3.75 3.75l1.83-1.83z"/>
            </svg>
        </a>
    </td>
</tr>