<%- include('partials/header') %>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-lg mt-4">
        <div class="card-header bg-primary text-white">
          <h5 class="card-title mb-0">Editar Contato</h5>
        </div>
        <div class="card-body p-4">
          <form action="/form" method="post">
            <input type="hidden" class="form-control form-control-lg" id="_id" name="_id" value="<%= contact._id %>" required>
            <div class="mb-3">
              <label for="nome" class="form-label fw-semibold">Nome Completo</label>
              <input type="text" class="form-control form-control-lg" id="nome" name="nome" value="<%= contact.nome %>" required>
              <small class="form-text text-muted">Nome completo do contato.</small>
            </div>

            <div class="mb-3">
              <label for="email" class="form-label fw-semibold">Email</label>
              <input type="email" class="form-control form-control-lg" id="email" name="email" value="<%= contact.email %>" required>
              <small class="form-text text-muted">Email do contato.</small>
            </div>

            <div class="mb-3">
              <label for="telefone" class="form-label fw-semibold">Telefone</label>
              <input type="text" class="form-control form-control-lg" id="telefone" name="telefone" value="<%= contact.telefone %>" placeholder="(xx) xxxxx-xxxx" required>
              <small class="form-text text-muted">Telefone do contato.</small>
            </div>

            <div class="mb-4">
              <div class="form-check form-switch">
                <% let checked = contact.favorito ? "checked" : "" %>
                <input class="form-check-input" type="checkbox" id="favorito" name="favorito" <%= checked %>>
                <label class="form-check-label fw-semibold" for="favorito">Marcar como favorito</label>
              </div>
            </div>

            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
              <button type="submit" class="btn btn-primary btn-lg px-4">Enviar</button>
              <button type="button" class="btn btn-outline-secondary btn-lg px-4" id="resetBtn">Limpar</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>